      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "// Keep only these SharePoint field names\nconst objectType = \"note\";\nconst keepFields = $('Sp Defaults').item.json.n8n_sharepoint.lists[objectType].fields;\n\nconst fields = $json?.fields ?? $json;\nconst ID = $json.id || $json.ID;\nconst JobNumber = fields.Title;\n\nconst item = Object.fromEntries(\n  Object.entries(fields).filter(([k]) => keepFields.includes(k))\n);\n\nreturn {\n  json: {\n    ID,\n    JobNumber,\n    [objectType]: {\n      ID,\n      JobNumber,\n      FolderSuffix: `${objectType}.${ID.padStart(6,'0')}`,\n      ...item\n    }\n  },\n  binary: $binary\n};"
        },
