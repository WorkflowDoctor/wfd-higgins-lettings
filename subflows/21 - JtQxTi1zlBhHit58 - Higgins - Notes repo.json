      },
      {
        "parameters": {
          "jsCode": "// Get EntryPoint item\nconst entry = $('EntryPoint').first();\n\n// Get all incoming items (job repo output)\nconst items = $input.all();\n\n// Conditions\nconst hasBinaryFlag = !!entry?.json?.binary;\nconst hasNote = !!entry?.json?.note;\nconst hasBinaryData = !!entry?.binary;\n\nif (hasBinaryFlag && hasNote && hasBinaryData && items.length > 0) {\n  // Clone first item to avoid mutation side-effects\n  const first = items[0];\n\n  items[0] = {\n    json: first.json,\n    binary: {\n      ...(first.binary || {}),\n      ...entry.binary // inject/merge binaries from EntryPoint\n    }\n  };\n}\n\n// Return all items\nreturn items;"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
