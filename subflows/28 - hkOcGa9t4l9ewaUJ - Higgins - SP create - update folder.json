      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "return { \n  json: {\n    id: $('PATCH (create folder)').item.json.id,\n    webUrl: $('PATCH (create folder)').item.json.webUrl,\n    n8n_sharepoint: $('_SharepointDefaults').item.json.n8n_sharepoint\n}};"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2144,
          -544
        ],
        "id": "03ed51cd-ee4d-437f-878a-330e74420523",
        "name": "Return id, webUrl"
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "const item = $json;\nconst sharepoint = $('_SharepointDefaults').item.json.n8n_sharepoint;\n\n// --- Get SharePoint column configuration ---\nconst spDriveDefaults = sharepoint.drives[\"_default\"];\nconst spListDefaults = sharepoint.lists[\"document\"];\nconst allowedColumns = spListDefaults.fields || [];\n\n// Timestamp internal column name\nconst timestampInternalField = spDriveDefaults.timestampColumn;\n\n// --- Existing + Incoming timestamps ---\nconst existingRaw = item.listItem?.fields?.[timestampInternalField];\nconst newRaw = $('Start').item.json.timestamp;\n\nconst existing = existingRaw ? new Date(existingRaw) : null;\nconst incoming = newRaw ? new Date(newRaw) : null;\n\nlet chosen = null;\n\nif (existing && !isNaN(existing) && incoming && !isNaN(incoming)) {\n  chosen = (existing <= incoming) ? existing : incoming;\n} else if (existing && !isNaN(existing)) {\n  chosen = existing;\n} else if (incoming && !isNaN(incoming)) {\n  chosen = incoming;\n}\n\n// --- Build metadata object ---\nconst startMetadata = $('Start').item.json.metadata || {};\nconst metadataObj =\n  typeof startMetadata === 'string'\n    ? JSON.parse(startMetadata)\n    : startMetadata;\n\n// Inject calculated timestamp BEFORE filtering\nif (chosen) {\n  metadataObj.Timestamp = chosen.toISOString();\n}\n\n// --- Filter metadata to only allowed SharePoint columns ---\nconst filteredMetadata = Object.fromEntries(\n  Object.entries(metadataObj).filter(([key]) =>\n    allowedColumns.includes(key)\n  )\n);\n\n// --- Return result ---\nreturn {\n  siteId: sharepoint.siteId,\n  listId: spListDefaults.sharepointId,\n  listItem: item.listItem,\n  timestamp: chosen ? chosen.toISOString() : null,\n  metadata: filteredMetadata\n};"
        },
