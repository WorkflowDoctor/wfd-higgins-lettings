        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "const folderType = $json.folderType || '';\nconst rootFolderPath = $json.n8n_sharepoint.drives[\"_default\"].paths[folderType];\n\nconst paddedId = $json.itemId ? `.${$json.itemId.padStart(6,'0')}` : '';\nconst relativePath = (folderType.toLowerCase() === 'root') ? $json.path : `${$json.path || ''}/${folderType || ''}${paddedId}`;\n\n// Path should be constructed unless folderType is root\nconst fullPath = `${rootFolderPath}/${relativePath}`;\n\nreturn {\n  json: {\n    fullPath,\n    ...$json,\n    ...$json.n8n_sharepoint\n  }\n}"
        },
