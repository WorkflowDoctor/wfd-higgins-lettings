          "name": "Skip Lookup"
        },
        {
          "parameters": {
            "mode": "runOnceForEachItem",
            "jsCode": "// Fields we want to keep from each address\nconst keep = [\n  \"premise\",\"line_1\",\"line_2\",\"line_3\",\"post_town\",\n  \"traditional_county\",\"county\",\"postcode\",\"country\",\n  \"id\",\"udprn\",\"umprn\",\"latitude\",\"longitude\"\n];\n\n// Original results array from Ideal Postcodes\nconst results = $json.result ?? [];\n\n// Filter each result object\nconst filteredResults = results.map(r => {\n  const out = {};\n  for (const k of keep) {\n    if (Object.prototype.hasOwnProperty.call(r, k)) {\n      out[k] = r[k];\n    }\n  }\n  return out;\n});\n\n// Postcode from SubWorkflow node\nconst inputPostcode = $('Defaults').first().json.postcode;\n\n// Return a single item, preserving schema shape\nreturn {\n  postcode: inputPostcode,\n  result: filteredResults,\n};"
          },
