      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "function decimalToDMS(decimal, isLatitude = true) {\n  const absolute = Math.abs(decimal);\n\n  const degrees = Math.floor(absolute);\n  const minutesFull = (absolute - degrees) * 60;\n  const minutes = Math.floor(minutesFull);\n  const seconds = (minutesFull - minutes) * 60;\n\n  const hemisphere = isLatitude\n    ? (decimal >= 0 ? 'N' : 'S')\n    : (decimal >= 0 ? 'E' : 'W');\n\n  return `${degrees}°${minutes.toString().padStart(2, '0')}'${seconds.toFixed(1).padStart(4, '0')}\"${hemisphere}`;\n}\n\nconst suggestions = $json?.fields?.JsonResponse ? JSON.parse($json?.fields?.JsonResponse) : {};\n\nconst enriched = suggestions?.result.map(s => {\n  const lat = Number(s.latitude);\n  const lng = Number(s.longitude);\n\n  if (!isFinite(lat) || !isFinite(lng)) {\n    return { ...s, location: '' };\n  }\n\n  return {\n    ...s,\n    location: `${decimalToDMS(lat, true)} ${decimalToDMS(lng, false)}`\n  };\n});\n\nreturn {\n  json: { \n    postcode: $('SubWorkflow').first().json.postcode,\n    address_suggestions: enriched\n  }\n};\n"
        },
