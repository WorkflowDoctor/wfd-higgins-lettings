                      "parameters":  {
                                         "jsCode":  "const original = $(\u0027Switch input\u0027).first();\nconst source = JSON.parse(JSON.stringify(original.json ?? {}));\nconst rows = $input.all().map(item =\u003e item.json ?? {});\n\nconst transition = source.body?.transition ?? {};\nconst currentStatus = String(\n  transition.CurrentStatus ?? source.body?.job?.Status ?? \u0027\u0027\n).trim();\n\nfunction matches(row, status) {\n  const mode = String(row.match_type ?? \u0027exact\u0027).trim().toLowerCase();\n  const raw = String(row.current_status ?? \u0027\u0027).trim();\n\n  if (mode === \u0027any\u0027) return true;\n  if (mode === \u0027prefix\u0027) return raw ? status.startsWith(raw) : true;\n  if (mode === \u0027one_of\u0027) {\n    return raw\n      .split(\u0027|\u0027)\n      .map(v =\u003e v.trim())\n      .filter(Boolean)\n      .includes(status);\n  }\n\n  return raw === status;\n}\n\nconst activeRows = rows.filter(row =\u003e String(row.is_active ?? \u0027true\u0027).toLowerCase() !== \u0027false\u0027);\nconst matchedRow = activeRows.find(row =\u003e matches(row, currentStatus));\n\nif (matchedRow?.next_status \u0026\u0026 source.body?.job) {\n  source.body.job.Status = matchedRow.next_status;\n}\n\nsource.transitionResult = {\n  matched: !!matchedRow,\n  event: transition.Event ?? \u0027\u0027,\n  actor: transition.Actor ?? \u0027\u0027,\n  currentStatus,\n  nextStatus: matchedRow?.next_status ?? source.body?.job?.Status ?? currentStatus,\n  handledBy: matchedRow?.handled_by ?? \u0027\u0027,\n  tableName: transition.TableName ?? \u0027\u0027\n};\n\nreturn [{\n  json: source,\n  binary: original.binary ?? {}\n}];"
                                     },
