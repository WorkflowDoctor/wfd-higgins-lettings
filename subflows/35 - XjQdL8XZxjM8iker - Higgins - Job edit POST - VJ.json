                                         "jsCode":  "function isPrimitiveLike(value) {\n  return (\n    value === null ||\n    [\u0027string\u0027, \u0027number\u0027, \u0027boolean\u0027].includes(typeof value)\n  );\n}\n\nfunction shouldUnwrapArray(value) {\n  return (\n    Array.isArray(value) \u0026\u0026\n    value.length === 1 \u0026\u0026\n    value.every(isPrimitiveLike)\n  );\n}\n\nfunction normalisePostedValue(value) {\n  // Step 1: unwrap single-item primitive arrays\n  if (shouldUnwrapArray(value)) {\n    value = value[0];\n  }\n\n  // Step 2: boolean coercion (only for strings)\n  if (typeof value === \u0027string\u0027) {\n    const v = value.trim().toLowerCase();\n\n    if (v === \u0027true\u0027) return true;\n    if (v === \u0027false\u0027) return false;\n  }\n\n  return value;\n}\n\nfunction setDeep(obj, path, value) {\n  const parts = String(path).split(\u0027.\u0027).filter(Boolean);\n  let cur = obj;\n\n  for (let i = 0; i \u003c parts.length; i++) {\n    const key = parts[i];\n    const isLast = i === parts.length - 1;\n\n    if (isLast) {\n      const incoming = normalisePostedValue(value);\n\n      if (Object.prototype.hasOwnProperty.call(cur, key)) {\n        cur[key] = Array.isArray(cur[key])\n          ? [...cur[key], incoming]\n          : [cur[key], incoming];\n      } else {\n        cur[key] = incoming;\n      }\n    } else {\n      if (cur[key] == null || typeof cur[key] !== \u0027object\u0027 || Array.isArray(cur[key])) {\n        cur[key] = {};\n      }\n      cur = cur[key];\n    }\n  }\n}\n\nfunction dedotObject(src) {\n  const out = {};\n  for (const [k, v] of Object.entries(src ?? {})) {\n    if (k.includes(\u0027.\u0027)) setDeep(out, k, v);\n    else out[k] = normalisePostedValue(v);\n  }\n  return out;\n}\n\nconst items = $input.all();\n\nreturn items.map(item =\u003e {\n  const body = item.json?.body ?? {};\n  const newBody = dedotObject(body);\n\n  return {\n    json: {\n      ...item.json,\n      body: newBody,\n    },\n    binary: {\n      ...item.binary\n    }\n  };\n});"
                                     },
