                                         "jsCode":  "// Grab the HTTP payload item\nconst item = $(\u0027Start\u0027).first().json;\n\n// Clone query object and normalise method\nconst query = {\n  ...(item.query || {}),\n  method: \"POST\"\n};\n\nfunction toQueryString(obj = {}) {\n  return Object.entries(obj)\n    .map(([k, v]) =\u003e\n      `${encodeURIComponent(k)}=${encodeURIComponent(v)}`\n    )\n    .join(\"\u0026\");\n}\n\nconst qs = toQueryString(query);\nconst queryString = qs ? `?${qs}` : \"\";\n\nconst returnTo = `${item.webhookUrl}${queryString}`;\n\nreturn [\n  {\n    json: {\n      FormType: $(\u0027Start\u0027).first().json.body?.FormType,\n      query,\n      result: $input.first().json,\n      statusCode: 302,\n      headers: {\n        Location: returnTo\n      }\n    }\n  }\n];\n\n\n"
