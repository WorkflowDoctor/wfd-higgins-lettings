          "html": "<!-- #pageTitle 'Job #{{ $json.job.JobNumber }}' -->\n<!-- #userEmail '{{ $json.user?.email }}' -->\n\n<!-- #jobCreated '{{ new Date($json.job?.Created || '').toLocaleString('en-GB') }}' -->\n<!-- #jobStatus '{{ $json.job?.Status || '' }}' -->\n\n<!-- Summary -->\n<div class=\"row mb-4\">\n    <div class=\"col-12\">\n        <div class=\"alert alert-info\">\n            {{ $json.job.Description }}\n        </div>\n    </div>\n</div>\n\n<!-- Location -->\n<div class=\"row mb-4\">\n    <div class=\"col-6\">\n        <h2>Location</h2>\n        <dl class=\"row\">\n            <dt class=\"col-4\">Address</dt>\n            <dd class=\"col-8\">{{ $json.job.Address }}</dd>\n\n            <dt class=\"col-4\">Postcode</dt>\n            <dd class=\"col-8\">{{ $json.job.Postcode }}</dd>\n\n            <dt class=\"col-4\">Contact</dt>\n            <dd class=\"col-8\">{{ $json.job.ContactForAccess }}</dd>\n\n            <dt class=\"col-4\">Contact number</dt>\n            <dd class=\"col-8\">{{ $json.job.ContactNumber }}</dd>\n\n            <dt class=\"col-4\">Key number</dt>\n            <dd class=\"col-8\">{{ $json.job.KeyNum ?? '' }}</dd>\n        </dl>\n    </div>\n\n    <div class=\"col-6\">\n        <iframe\n            class=\"border rounded\"\n            style=\"width:100%; min-height:300px;\"\n            src=\"https://www.google.com/maps/embed/v1/search?q={{ encodeURIComponent($json.job.AddressLatLong ?? ($json.job.Postcode + ' UK')) }}&amp;key={{ $json.n8n_defaults.google_cloud.MapsApiKey }}\">\n        </iframe>\n    </div>\n</div>\n\n<!-- Details -->\n<div class=\"row mb-4\">\n    <div class=\"col-12\">\n        <h2>Details</h2>\n        <div class=\"border rounded p-3 bg-light\">\n            {{ $json.job.Description }}\n        </div>\n    </div>\n</div>\n\n<!-- Attributes -->\n<div class=\"row mb-4\">\n    <div class=\"col-12\">\n        <dl class=\"row\">\n\n            <dt class=\"col-3\">Priority</dt>\n            <dd class=\"col-9\">\n     