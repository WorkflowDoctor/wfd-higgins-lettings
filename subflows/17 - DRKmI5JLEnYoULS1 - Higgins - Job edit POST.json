        "parameters": {
          "jsCode": "// Grab the HTTP payload item\nconst item = $('Start').first().json;\n\n// Clone query object and normalise method\nconst query = {\n  ...(item.query || {}),\n  method: \"POST\"\n};\n\nfunction toQueryString(obj = {}) {\n  return Object.entries(obj)\n    .map(([k, v]) =>\n      `${encodeURIComponent(k)}=${encodeURIComponent(v)}`\n    )\n    .join(\"&\");\n}\n\nconst qs = toQueryString(query);\nconst queryString = qs ? `?${qs}` : \"\";\n\nconst returnTo = `${item.webhookUrl}${queryString}`;\n\nreturn [\n  {\n    json: {\n      FormType: $('Start').first().json.body?.FormType,\n      query,\n      result: $input.first().json,\n      statusCode: 302,\n      headers: {\n        Location: returnTo\n      }\n    }\n  }\n];\n\n\n"
