        "id": "5f66f4d6-236c-422e-addd-c3ca78a76109",
        "name": "Request Auth Token"
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "const crypto = require(\"crypto\");\n\n// Get state from the original call\nconst stateParam = $('AuthCallback').first().json.query?.state;\n\nlet returnTo = \"https://drflow.co.uk/\"; // safe fallback\n\nif (stateParam) {\n  try {\n    const decoded = JSON.parse(\n      globalThis.Buffer.from(stateParam, \"base64url\").toString(\"utf8\")\n    );\n    if (decoded.returnTo) {\n      returnTo = decoded.returnTo;\n    }\n  } catch (e) {\n    // ignore malformed state\n  }\n}\n\n// Get first input item safely\nconst input = $json;\n\n// --- decode auth id_token ---\nfunction base64urlDecode(input) {\n  input = input.replace(/-/g, \"+\").replace(/_/g, \"/\");\n  const pad = input.length % 4;\n  if (pad) input += \"=\".repeat(4 - pad);\n  return globalThis.Buffer.from(input, \"base64\").toString(\"utf8\");\n}\n\nconst idToken = input.id_token;\nconst claims = JSON.parse(base64urlDecode(idToken.split(\".\")[1]));\n\nconsole.log(`Claims`, claims);\n\n// --- create session payload ---\nconst payload = {\n  sub: claims.sub,\n  email: claims.email || claims.preferred_username,\n  tid: claims[\"https://workflowdoctor.co.uk/tenantid\"],\n  connection: claims[\"https://workflowdoctor.co.uk/connection\"],\n  exp: Math.floor(Date.now() / 1000) + (2 * 60 * 60) // 2 hours\n};\n\nconsole.log(`Payload`, payload);\n\n// --- sign payload ---\nconst payloadB64 = globalThis.Buffer\n  .from(JSON.stringify(payload))\n  .toString(\"base64url\");\n\nconst signature = crypto\n  .createHmac(\"sha256\", input.n8n_secrets.n8n_session_secret)\n  .update(payloadB64)\n  .digest(\"hex\");\n\nconst sessionToken = `${payloadB64}.${signature}`;\n\nlet response = {\n  statusCode: 303, \n  headers: { \n    \"Set-Cookie\": `${input.n8n_secrets.auth0.cookie_name}=${sessionToken}; HttpOnly; Secure; SameSite=Lax; Path=/`,\n    Location: returnTo\n  }\n};\n\nreturn response; "
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1120,
          280
        ],
