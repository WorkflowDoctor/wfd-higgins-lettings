          "parameters": {
            "jsCode": "const item = $input.first().json;\n\nconst entra = item.n8n_secrets?.entra || {};\nconst tenantId = entra.tenant_id;\nconst cookieName = entra.cookie_name || \"session\";\n\n// Where to send the user after full logout\nconst postLogoutRedirect = item.query?.returnTo || \"https://drflow.co.uk/\"; // set a sensible default\n\nconst clearedCookie =\n  `${cookieName}=; Path=/; Max-Age=0; Expires=Thu, 01 Jan 1970 00:00:00 GMT; ` +\n  `HttpOnly; Secure; SameSite=Lax`;\n\n// If you want Entra logout too:\nconst location = tenantId\n  ? `https://login.microsoftonline.com/${encodeURIComponent(tenantId)}/oauth2/v2.0/logout` +\n    `?post_logout_redirect_uri=${encodeURIComponent(postLogoutRedirect)}`\n  : postLogoutRedirect;\n\nreturn [{\n  json: {\n    statusCode: 303,\n    headers: {\n      \"Set-Cookie\": clearedCookie,\n      Location: location,\n      \"Cache-Control\": \"no-store\",\n    }\n  }\n}];\n"
